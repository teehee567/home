export struct WatchedAppData {
    display-name: string,
    exe-path: string,
    is-online: bool,
    has-error: bool,
    error-text: string,
}

export component AppWatcherPage inherits Rectangle {
    in property <[WatchedAppData]> apps: [];
    in-out property <int> selected-index: -1;

    callback add-app();
    callback remove-app(int);

    VerticalLayout {
        padding: 20px;
        spacing: 12px;

        Text {
            text: "App Watcher";
            color: #e6edf3;
            font-size: 14px;
            font-weight: 600;
        }

        Rectangle { height: 1px; background: #161b22; }

        Rectangle {
            vertical-stretch: 1;
            background: #0d1117;
            border-radius: 6px;
            border-width: 1px;
            border-color: #21262d;
            clip: true;

            VerticalLayout {
                Flickable {
                    vertical-stretch: 1;
                    viewport-height: list-layout.preferred-height;

                    list-layout := VerticalLayout {
                        spacing: 0px;

                        if root.apps.length == 0 : Rectangle {
                            height: 60px;
                            Text {
                                text: "No apps being watched. Press + to add one.";
                                color: #484f58;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        for app[idx] in root.apps : Rectangle {
                            height: 40px;
                            background: root.selected-index == idx ? #161b22 : (row-ta.has-hover ? #0f1318 : transparent);

                            row-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if root.selected-index == idx {
                                        root.selected-index = -1;
                                    } else {
                                        root.selected-index = idx;
                                    }
                                }
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: start;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: app.has-error ? #f85149 : (app.is-online ? #3fb950 : #f85149);
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 1px;

                                    HorizontalLayout {
                                        spacing: 6px;

                                        Text {
                                            text: app.display-name;
                                            color: app.has-error ? #f85149 : #e6edf3;
                                            font-size: 12px;
                                            font-weight: 500;
                                            overflow: elide;
                                        }
                                    }

                                    if app.has-error : Text {
                                        text: app.error-text;
                                        color: #f85149;
                                        font-size: 10px;
                                        overflow: elide;
                                    }

                                    if !app.has-error : Text {
                                        text: app.exe-path;
                                        color: #484f58;
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }
                            }

                            if idx < root.apps.length - 1 : Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                x: 12px;
                                width: parent.width - 24px;
                                background: #161b22;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: #21262d;
                }

                HorizontalLayout {
                    padding: 6px;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;

                    add-btn := Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 6px;
                        background: add-ta.has-hover ? #1f2937 : #161b22;
                        border-width: 1px;
                        border-color: #30363d;

                        add-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.add-app(); }
                        }

                        Text {
                            text: "+";
                            color: #3fb950;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    remove-btn := Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 6px;
                        background: root.selected-index >= 0 ? (rem-ta.has-hover ? #1f2937 : #161b22) : #0d1117;
                        border-width: 1px;
                        border-color: root.selected-index >= 0 ? #30363d : #21262d;

                        rem-ta := TouchArea {
                            mouse-cursor: root.selected-index >= 0 ? pointer : default;
                            clicked => {
                                if root.selected-index >= 0 {
                                    root.remove-app(root.selected-index);
                                    root.selected-index = -1;
                                }
                            }
                        }

                        Text {
                            text: "\u{2212}";
                            color: root.selected-index >= 0 ? #f85149 : #484f58;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }
    }
}
