export component GenshinView inherits Rectangle {
    background: #0d1117;

    in property <string> fps_text: "---";
    in property <string> status_text: "Genshin Impact not running";
    in property <bool> running: false;

    VerticalLayout {
        alignment: center; padding: 28px; spacing: 8px;
        Text { text: "GENSHIN IMPACT"; color: #c8a96e; font-size: 11px; horizontal-alignment: center; }
        HorizontalLayout {
            alignment: center; spacing: 10px;
            Text { text: root.fps_text; color: root.running ? #e8f0e8 : #303030; font-size: 68px; font-weight: 700; vertical-alignment: center; }
            Text { text: "FPS"; color: root.running ? #c8a96e : #303030; font-size: 14px; font-weight: 700; vertical-alignment: center; }
        }
        Rectangle { height: 1px; background: #1e2433; }
        Text { text: root.status_text; color: #505a6e; font-size: 11px; horizontal-alignment: center; }
    }
}
