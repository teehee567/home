import { Dashboard } from "pages/dashboard.slint";
import { GenshinPage, WishStatCard, WishGraphData, WishBreakdown, WishPill } from "modules/genshin.slint";
import { AppWatcherPage, WatchedAppData } from "modules/app_watcher.slint";
import { MetricsPage, MetricStat, GraphData } from "modules/metrics.slint";

export { MetricStat, GraphData, WishStatCard, WishGraphData, WishBreakdown, WishPill }

component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    height: 28px;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        Rectangle {
            width: 2px;
            background: root.active ? #58a6ff : transparent;
        }

        HorizontalLayout {
            padding-left: 10px;

            Text {
                text: root.label;
                color: root.active ? #e6edf3 : ta.has-hover ? #b1bac4 : #7d8590;
                font-size: 12px;
                font-weight: root.active ? 600 : 400;
                vertical-alignment: center;
            }
        }
    }
}

component PlaceholderPage inherits Rectangle {
    in property <string> title;

    VerticalLayout {
        padding: 20px;
        spacing: 4px;

        Text {
            text: root.title;
            color: #e6edf3;
            font-size: 14px;
            font-weight: 600;
        }

        Text {
            text: "Not implemented";
            color: #484f58;
            font-size: 11px;
        }

        Rectangle { vertical-stretch: 1; }
    }
}

export component App inherits Window {
    title: "noob";
    icon: @image-url("../../../data/icons/larger_noob.png");
    preferred-width: 880px;
    preferred-height: 520px;
    min-width: 700px;
    min-height: 440px;
    background: #0d1117;

    in property <string> fps-text: "---";
    in property <string> status-text: "Genshin Impact not running";
    in property <bool> running: false;

    // genshin wishes
    in property <[string]> gi-banner-names: [];
    in property <int> gi-selected: 0;
    in property <[WishStatCard]> gi-overview: [];
    in property <WishGraphData> gi-graph;
    in property <WishBreakdown> gi-breakdown;
    in property <[WishPill]> gi-pills: [];
    in property <string> gi-wish-status: "Open your in-game wish history, then Update.";
    in property <bool> gi-wish-busy: false;
    callback gi-update();
    callback gi-full-refresh();
    callback gi-export-file();
    callback gi-select-banner(int);
    callback gi-wish-resized(length, length);

    // star rail warps
    in property <[string]> hsr-banner-names: [];
    in property <int> hsr-selected: 0;
    in property <[WishStatCard]> hsr-overview: [];
    in property <WishGraphData> hsr-graph;
    in property <WishBreakdown> hsr-breakdown;
    in property <[WishPill]> hsr-pills: [];
    in property <string> hsr-wish-status: "Open your in-game warp history, then Update.";
    in property <bool> hsr-wish-busy: false;
    callback hsr-update();
    callback hsr-full-refresh();
    callback hsr-export-file();
    callback hsr-select-banner(int);
    callback hsr-wish-resized(length, length);

    in property <string> server-value: "---";
    in property <string> server-status: "Not connected";
    in property <bool> server-connected: false;

    in property <[MetricStat]> metrics-stats: [];
    in property <[GraphData]> metrics-left: [];
    in property <[GraphData]> metrics-right: [];
    in property <string> metrics-status: "Not connected";
    in property <bool> metrics-connected: false;
    callback metrics-resized(length, length);

    in property <[WatchedAppData]> watcher-apps: [];
    in-out property <int> watcher-selected: -1;
    callback watcher-add-app();
    callback watcher-remove-app(int);

    property <int> current-tab: 0;

    HorizontalLayout {
        Rectangle {
            width: 110px;
            background: #010409;

            VerticalLayout {
                padding-top: 12px;
                spacing: 0px;

                NavItem { label: "Dashboard"; active: current-tab == 0; clicked => { current-tab = 0; } }
                NavItem { label: "Metrics"; active: current-tab == 1; clicked => { current-tab = 1; } }
                NavItem { label: "Genshin"; active: current-tab == 2; clicked => { current-tab = 2; } }
                NavItem { label: "App Watcher"; active: current-tab == 3; clicked => { current-tab = 3; } }
                NavItem { label: "Finance"; active: current-tab == 4; clicked => { current-tab = 4; } }
                NavItem { label: "Star Rail"; active: current-tab == 5; clicked => { current-tab = 5; } }
                NavItem { label: "Uni"; active: current-tab == 6; clicked => { current-tab = 6; } }
                NavItem { label: "Nutrition"; active: current-tab == 7; clicked => { current-tab = 7; } }
                NavItem { label: "Files"; active: current-tab == 8; clicked => { current-tab = 8; } }

                Rectangle { vertical-stretch: 1; }

                Rectangle { height: 1px; background: #21262d; }
                NavItem { label: "Settings"; active: current-tab == 9; clicked => { current-tab = 9; } }
                Rectangle { height: 4px; }
            }
        }

        Rectangle { width: 1px; background: #21262d; }

        Rectangle {
            horizontal-stretch: 1;

            if current-tab == 0 : Dashboard {
                fps-text: root.fps-text;
                status-text: root.status-text;
                running: root.running;
                server-value: root.server-value;
                server-status: root.server-status;
                server-connected: root.server-connected;
            }
            if current-tab == 1 : MetricsPage {
                stats: root.metrics-stats;
                series-left: root.metrics-left;
                series-right: root.metrics-right;
                status: root.metrics-status;
                connected: root.metrics-connected;
                plot-resized(w, h) => { root.metrics-resized(w, h); }
            }
            if current-tab == 2 : GenshinPage {
                fps-text: root.fps-text;
                status-text: root.status-text;
                running: root.running;

                gi-banner-names: root.gi-banner-names;
                gi-selected: root.gi-selected;
                gi-overview: root.gi-overview;
                gi-graph: root.gi-graph;
                gi-breakdown: root.gi-breakdown;
                gi-pills: root.gi-pills;
                gi-status: root.gi-wish-status;
                gi-busy: root.gi-wish-busy;
                gi-update => { root.gi-update(); }
                gi-full-refresh => { root.gi-full-refresh(); }
                gi-export-file => { root.gi-export-file(); }
                gi-select-banner(i) => { root.gi-select-banner(i); }
                gi-resized(w, h) => { root.gi-wish-resized(w, h); }

                hsr-banner-names: root.hsr-banner-names;
                hsr-selected: root.hsr-selected;
                hsr-overview: root.hsr-overview;
                hsr-graph: root.hsr-graph;
                hsr-breakdown: root.hsr-breakdown;
                hsr-pills: root.hsr-pills;
                hsr-status: root.hsr-wish-status;
                hsr-busy: root.hsr-wish-busy;
                hsr-update => { root.hsr-update(); }
                hsr-full-refresh => { root.hsr-full-refresh(); }
                hsr-export-file => { root.hsr-export-file(); }
                hsr-select-banner(i) => { root.hsr-select-banner(i); }
                hsr-resized(w, h) => { root.hsr-wish-resized(w, h); }
            }
            if current-tab == 3 : AppWatcherPage {
                apps: root.watcher-apps;
                selected-index <=> root.watcher-selected;
                add-app => { root.watcher-add-app(); }
                remove-app(idx) => { root.watcher-remove-app(idx); }
            }
            if current-tab == 4 : PlaceholderPage { title: "Finance"; }
            if current-tab == 5 : PlaceholderPage { title: "Star Rail"; }
            if current-tab == 6 : PlaceholderPage { title: "Uni"; }
            if current-tab == 7 : PlaceholderPage { title: "Nutrition"; }
            if current-tab == 8 : PlaceholderPage { title: "Files"; }
            if current-tab == 9 : PlaceholderPage { title: "Settings"; }
        }
    }
}
